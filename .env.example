# Twitch app — https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret

# Compte bot IRC (chat:read) — format oauth:xxxxxxxxxxxx
TWITCH_IRC_TOKEN=oauth:your_irc_token
TWITCH_IRC_NICK=your_bot_username

# Token clips:edit (sans préfixe oauth:) — générer via : python -m src.main auth
TWITCH_USER_TOKEN=your_user_token

# Analyse IA des clips (DeepSeek V4 Flash)
DEEPSEEK_API_KEY=

# Répertoire de sortie (défaut : ./data)
# DATA_DIR=./data
