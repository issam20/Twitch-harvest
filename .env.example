# Twitch API
TWITCH_CLIENT_ID=your_client_id
TWITCH_CLIENT_SECRET=your_client_secret
# OAuth token pour le chat (scope chat:read). Preferer un compte bot dedie.
TWITCH_IRC_TOKEN=oauth:xxxxxxxxxxxxxxxxxxxx
TWITCH_IRC_NICK=your_bot_username

# Claude (phase 2+)
ANTHROPIC_API_KEY=sk-ant-xxx

# Paths
DATA_DIR=./data
